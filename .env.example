# O proxy do Vite já roteia /api/v1/* para os serviços corretos.
# Não altere VITE_API_URL em desenvolvimento — deixe como /api/v1
VITE_API_URL=/api/v1
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Portas dos serviços (referência — configuradas em vite.config.ts)
# Auth:        localhost:8081
# Character:   localhost:8082
# Progression: localhost:8083
# Inventory:   localhost:8084
